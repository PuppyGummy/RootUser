--- !u!114 &45203323
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 45203321}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "from PIL import Image\r\n\r\ndef decode_image(image_path):\r\n    with
    Image.open(image_path) as image:\r\n        pixels = image.load()\r\n       
    width, height = image.size\r\n        hidden_text = \"\"\r\n        for y in
    range(height):\r\n            for x in range(width):\r\n                r, g,
    b = pixels[x, y]\r\n                hidden_text += chr(r & 3) + chr(g & 3) +
    chr(b & 3)\r\n        return hidden_text.rstrip(\"\\x00\")\r\n\r\ndef decode_secret_message(image_path):\r\n   
    hidden_text = decode_image(image_path)\r\n    decoded_text = \"\"\r\n    try:\r\n       
    decoded_text = hidden_text.decode(\"utf-8\")\r\n    except UnicodeDecodeError:\r\n       
    pass\r\n    if decoded_text:\r\n        return decoded_text\r\n    else:\r\n       
    key = \"\"\r\n        for char in hidden_text:\r\n            key_char = ord(char)
    % 256\r\n            key += chr(key_char)\r\n        try:\r\n            decoded_text
    = hidden_text.decode(key)\r\n        except UnicodeDecodeError:\r\n           
    pass\r\n        if decoded_text:\r\n            return decoded_text\r\n    return
    None\r\n\r\nsecret_message = decode_secret_message(\"example.png\")\r\nif secret_message:\r\n   
    print(secret_message)\r\nelse:\r\n    print(\"No hidden message found in the
    image.\")"
  m_isRightToLeft: 0
